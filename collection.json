    {
      "name": "Budgets",
      "item": [
        {
          "name": "Listar Orçamentos",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}/budgets?month=3&year=2026",
              "host": ["{{baseUrl}}"],
              "path": ["groups", "{{groupId}}", "budgets"],
              "query": [
                { "key": "month", "value": "3" },
                { "key": "year", "value": "2026" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Criar Orçamento",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) pm.collectionVariables.set('budgetId', res.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/groups/{{groupId}}/budgets",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": \"{{categoryId}}\",\n  \"month\": 3,\n  \"year\": 2026,\n  \"limitAmount\": 1000.00\n}"
            }
          }
        },
        {
          "name": "Atualizar Orçamento",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/groups/{{groupId}}/budgets/{{budgetId}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"limitAmount\": 1500.00\n}"
            }
          }
        },
        {
          "name": "Deletar Orçamento",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/groups/{{groupId}}/budgets/{{budgetId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Criar Orçamento Duplicado (409)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/groups/{{groupId}}/budgets",
