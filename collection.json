{
  "info": {
    "name": "FinTrack API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "groupId", "value": "" },
    { "key": "userId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "paymentMethodId", "value": "" },
    { "key": "transactionId", "value": "" },
    { "key": "budgetId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "  pm.collectionVariables.set('userId', res.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Joao Fleming\",\n  \"email\": \"joao@fintrack.com\",\n  \"password\": \"Senha123\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "  pm.collectionVariables.set('userId', res.user.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao@fintrack.com\",\n  \"password\": \"Senha123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/refresh",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{refreshToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/forgot-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"joao@fintrack.com\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/reset-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"COLE_O_TOKEN_DO_CONSOLE_AQUI\",\n  \"newPassword\": \"NovaSenha123\"\n}"
            }
          }
        },
        {
          "name": "Register — Senha Fraca (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Teste\",\n  \"email\": \"teste@test.com\",\n  \"password\": \"fraca\"\n}"
            }
          }
        },
        {
          "name": "Register — Email Duplicado (409)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Joao Fleming\",\n  \"email\": \"joao@fintrack.com\",\n  \"password\": \"Senha123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Groups",
      "item": [
        {
          "name": "Listar Grupos",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.length > 0) {",
                  "  pm.collectionVariables.set('groupId', res[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/groups",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Criar Grupo",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.id) {",
                  "  pm.collectionVariables.set('groupId', res.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/groups",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Grupo da Família\"\n}"
            }
          }
        },
        {
          "name": "Adicionar Membro",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/groups/{{groupId}}/members",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"outro@fintrack.com\",\n  \"role\": \"MEMBER\"\n}"
            }
          }
        },
        {
          "name": "Remover Membro",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/groups/{{groupId}}/members/{{userId}}",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Criar Grupo — Nome Curto (400)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/groups",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"A\"\n}"
            }
          }
        },
        {
          "name": "Listar Grupos — Sem Token (401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/groups"
          }
        }
      ]
    }
    ,
