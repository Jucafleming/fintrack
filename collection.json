              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/groups/{{groupId}}/transactions",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
          }
        },
        {
          "name": "Listar Transações — Filtro por Mês/Ano",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/groups/{{groupId}}/transactions?month=3&year=2026",
              "query": [
                { "key": "month", "value": "3" },
                { "key": "year", "value": "2026" }
              ]
            },
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
